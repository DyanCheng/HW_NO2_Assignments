@model List<Student>
@{
    ViewData["Title"] = "Danh sách sinh viên";
}

<h2>Danh sách sinh viên</h2>

@if (TempData["SuccessMessage"] is not null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (Model.Count == 0)
{
    <p class="text-muted">Chưa có dữ liệu sinh viên.</p>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.Name</td>
                    <td>@item.Email</td>
                    <td>@item.Phone</td>
                    <td>
                        <a asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-action="Create" class="btn btn-success">Thêm sinh viên mới</a>

@section Scripts {
    <script>
        console.log("Trang danh sách sinh viên đã được tải");
    </script>
}
