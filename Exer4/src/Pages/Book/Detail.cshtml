@page "{id:int}"
@model Exer4.Pages.Book.DetailModel
@{
    ViewData["Title"] = "Book Detail";
}

<h2>Chi tiết sách</h2>

@if (Model.Book == null)
{
    <div class="alert alert-danger">Không tìm thấy sách.</div>
}
else
{
    <div>
        <strong>Id:</strong> @Model.Book.Id <br />
        <strong>Tên sách:</strong> @Model.Book.Name <br />
        <strong>Giá:</strong> @Model.Book.Price <br />
    </div>
}

<div class="mt-3">
    <a asp-page="./Index" class="btn btn-secondary">Quay lại danh sách</a>
</div>
