@model List<Book>
@{
    ViewData["Title"] = "Danh sách sách";
}

<h2>Danh sách sách</h2>

@if (TempData["SuccessMessage"] is not null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (Model.Count == 0)
{
    <p class="text-muted">Chưa có dữ liệu sách.</p>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Tên</th>
                <th>Giá</th>
                <th>Hình ảnh</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Name</td>
                    <td>@item.Price.ToString("N2")</td>
                    <td>
                        @if (item.ImagePaths.Count == 0)
                        {
                            <span class="text-muted">Chưa có ảnh</span>
                        }
                        else
                        {
                            <div class="d-flex flex-wrap gap-2">
                                @foreach (var imagePath in item.ImagePaths)
                                {
                                    <img src="@imagePath" alt="@item.Name" class="product-thumbnail" />
                                }
                            </div>
                        }
                    </td>
                    <td>
                        <a asp-action="Detail" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<a asp-action="Create" class="btn btn-success">Thêm sách mới</a>
