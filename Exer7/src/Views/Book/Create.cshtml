@model Book
@{
    ViewData["Title"] = "Thêm sách";
}

<h2>Thêm sách mới</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Hình sản phẩm</label>
        <input type="file" name="images" class="form-control" accept=".jpg,.jpeg,.png" multiple />
        <div class="form-text">Chọn một hoặc nhiều ảnh (jpg/png).</div>
        <span class="text-danger field-validation-valid" data-valmsg-for="images" data-valmsg-replace="true"></span>
        @if (ViewData.ModelState["images"]?.Errors.Count > 0)
        {
            <span class="text-danger">@ViewData.ModelState["images"]!.Errors[0].ErrorMessage</span>
        }
    </div>

    <button type="submit" class="btn btn-primary">Lưu</button>
    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
